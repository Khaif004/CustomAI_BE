{
  "xsappname": "btp-copilot",
  "tenant-mode": "dedicated",
  "description": "Security configuration for Langchain Chatbot",
  "scopes": [
    {
      "name": "$XSAPPNAME.User",
      "description": "Authenticated user"
    }
  ],
  "role-templates": [
    {
      "name": "User",
      "description": "Chatbot User",
      "scope-references": [
        "$XSAPPNAME.User"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "ChatbotUser",
      "description": "Chatbot User Role Collection",
      "role-template-references": [
        "$XSAPPNAME.User"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "http://localhost:5000/**",
      "https://*.cfapps.eu10.hana.ondemand.com/**",
      "https://*.hana.ondemand.com/**"
    ],
    "token-validity": 3600,
    "refresh-token-validity": 86400
  }
}
